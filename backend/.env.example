# App
APP_ENV=production
SECRET_KEY="longrandomstring"
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/broadmail

# Redis
REDIS_URL=redis://localhost:6379

# Sending mode
# queue  -> requires Redis + worker service
# inline -> sends immediately in API process (no worker)
SEND_MODE=queue

# Email — Resend (primary)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Email — SMTP (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourorg@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_USE_TLS=true

# Tracking
TRACKING_BASE_URL=http://localhost:8000
UNSUBSCRIBE_SECRET="longrandomstring"

# Admin seed
FIRST_ADMIN_EMAIL=admin@enactusknust.org
FIRST_ADMIN_PASSWORD=admin
